    },
}

[
    enhanced_http_file(
        name = "com_github_mvdan_gofumpt_" + plat,
        downloaded_file_path = "gofumpt",
        executable = True,
        purl_pattern = "pkg:github/mvdan/gofumpt@{version}",
        sha256 = sha256,
        substitutions = {
            "{platform}": plat,
        },
        urls = [
            "https://github.com/mvdan/gofumpt/releases/download/v{version}/gofumpt_v{version}_{platform}",
        ],
        version = GOFUMPT_VERSION,
    )
    for plat, sha256 in GOFUMPT[GOFUMPT_VERSION].items()
]
