        "darwin-arm64": "234463f059249f82045824afdcdd5db5682d0593052f58f6a3039a0a1c3899f6",
    },
}

golangci_lint_version = "1.55.2"

[
    enhanced_http_archive(
        name = "golangci_lint_" + plat.replace("-", "_"),
        build_file_content = """exports_files(["golangci-lint"])""",
        purl_pattern = "pkg:github/golangci/golangci-lint@{version}",
        sha256 = sha256,
        strip_prefix = "golangci-lint-{version}-{platform}",
        substitutions = {
            "{platform}": plat,
        },
        url_pattern = "https://github.com/golangci/golangci-lint/releases/download/v{version}/golangci-lint-{version}-{platform}.tar.gz",
        version = golangci_lint_version,
    )
    for plat, sha256 in GOLANGCI_LINT[golangci_lint_version].items()
]

