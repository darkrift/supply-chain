module(
    name = "enhanced_http_tools_examples",
    version = "",  # Automatically updated by release pipeline.
)

bazel_dep(name = "enhanced_http_tools", version = "HEAD")
bazel_dep(name = "package_metadata", version = "HEAD")

local_path_override(
    module_name = "enhanced_http_tools",
    path = "../enhanced_http_tools",
)

local_path_override(
    module_name = "package_metadata",
    path = "../metadata",
)

enhanced_http_archive = use_repo_rule("@enhanced_http_tools//:defs.bzl", "enhanced_http_archive")
enhanced_http_file = use_repo_rule("@enhanced_http_tools//:defs.bzl", "enhanced_http_file")

GOLANGCI_LINT = {
    "1.55.2": {
        "linux-amd64": "ca21c961a33be3bc15e4292dc40c98c8dcc5463a7b6768a3afc123761630c09c",
        "linux-arm64": "8eb0cee9b1dbf0eaa49871798c7f8a5b35f2960c52d776a5f31eb7d886b92746",
