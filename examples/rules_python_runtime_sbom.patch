 load(":common_labels.bzl", "labels")
 load(":reexports.bzl", "BuiltinPyRuntimeInfo")
 
+_PYTHON_TOOLCHAIN_TYPE = Label("//python:toolchain_type")
+
+def _version_info_part(version_info, name):
+    if type(version_info) == type({}):
+        return version_info.get(name)
+    if hasattr(version_info, name):
+        return getattr(version_info, name)
+    return None
+
+def _python_runtime_version(runtime):
+    version_info = runtime.interpreter_version_info
+    parts = [
+        _version_info_part(version_info, "major"),
+        _version_info_part(version_info, "minor"),
+        _version_info_part(version_info, "micro"),
+    ]
+    if None in parts or "" in parts:
+        return runtime.python_version
+    return ".".join([str(part) for part in parts])
+
+def _python_runtime_package_metadata(ctx, runtime):
+    version = _python_runtime_version(runtime)
+    metadata = ctx.actions.declare_file(ctx.label.name + ".python-runtime.package-metadata.json")
+    ctx.actions.write(
+        output = metadata,
+        content = json.encode({
+            "attributes": {},
+            "label": str(ctx.label),
+            "purl": "pkg:generic/cpython@%s" % version,
+        }),
+    )
+    return PackageMetadataInfo(metadata = metadata)
+
