def _is_alpha(c):
    """Returns whether the given character is an alphabetic character."""

    return (_property_bits[c] & 0x01) != 0

def _is_alphanumeric(c):
    """Returns whether the given character is an alphanumeric character."""

    return (_property_bits[c] & 0x04) != 0

ascii = struct(
    is_alpha = _is_alpha,
    is_alphanumeric = _is_alphanumeric,
)
