# Precomputed lookup tables
_CHAR_TO_BYTE = {c: i for i, c in enumerate(_ALL_BYTES.elems())}
_BYTE_TO_CHAR = {i: c for i, c in enumerate(_ALL_BYTES.elems())}

def chr(byte_value):
    """Converts a byte value to a character.

    Args:
      byte_value (int): The byte value (0-255) to convert.

    Returns:
      A single-character string in Bazel's native encoding.
    """
    return _BYTE_TO_CHAR[byte_value]

def ord(char):
    """Converts a character to its byte value.

    Args:
      char (string): A single-character string to convert.

    Returns:
      The byte value (0-255) of the character.
    """
    return _CHAR_TO_BYTE[char]
